  },
  "dependencies": {
    "@giscus/react": "^3.1.0",
    "@opennextjs/cloudflare": "^1.20.1",
    "gray-matter": "^4.0.3",
    "lucide-react": "latest",
    "micromark": "^4.0.2",
    "next": "latest",
    "react": "latest",
    "react-dom": "latest"
  },
  "devDependencies": {
    "@eslint/eslintrc": "latest",
    "@tailwindcss/postcss": "latest",
    "@types/node": "latest",
    "@types/react": "latest",
    "@types/react-dom": "latest",
    "eslint": "latest",
    "eslint-config-next": "latest",
    "playwright": "^1.61.0",
    "tailwindcss": "latest",
    "typescript": "latest",
    "wrangler": "^4.105.0"
  }
